# ============================================================
# CodexConclave — Environment Variable Reference
# Copy this file to .env and fill in your values.
# ============================================================

# ─── LLM Provider Keys ──────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
GROQ_API_KEY=your-groq-api-key
MISTRAL_API_KEY=your-mistral-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── Azure OpenAI ───────────────────────────────────────────
AZURE_API_KEY=your-azure-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-15-preview

# ─── AWS Bedrock ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1

# ─── Memory Configuration ───────────────────────────────────
# Backend: "memory" (in-process, no persistence) or "lancedb"
CODEX_MEMORY_BACKEND=memory
CODEX_MEMORY_PATH=./chronicle_data

# ─── Observability ──────────────────────────────────────────
# Set to "true" to disable telemetry (e.g. during local dev)
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=codexconclave
# Custom OTLP collector endpoint (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Logging ────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
CODEX_LOG_LEVEL=INFO
